# Auth.js
AUTH_SECRET=<generate with: openssl rand -hex 32>
NEXTAUTH_URL=https://contentflow.vercel.app  # Only needed in production

# Turso Database
TURSO_CONNECTION_URL=libsql://[database-name]-[account].turso.io
TURSO_AUTH_TOKEN=<get from turso auth tokens create>

# Dropbox API
DROPBOX_ACCESS_TOKEN=<from your app>
DROPBOX_APP_KEY=<from your app>
DROPBOX_APP_SECRET=<from your app>
DROPBOX_FOLDER_PATH=/Foam  # Path to your Dropbox folder

# GitHub Actions Cron
CRON_API_KEY=<random-64-char-string>

# Meta Graph API (Phase 2)
# FACEBOOK_PAGE_ID=<your-page-id>
# FACEBOOK_TOKEN=<long-lived-page-token>
# INSTAGRAM_BUSINESS_ACCOUNT_ID=<your-account-id>

# Claude API (Phase 2)
# ANTHROPIC_API_KEY=<your-key>

# Logging
LOG_LEVEL=info
NODE_ENV=production
